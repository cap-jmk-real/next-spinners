{
  "name": "next-spinners",
  "version": "0.1.8",
  "description": "React & Next.js Braille/Unicode frame spinners, no CSS. shadcn registry. Optional next-spinners/loading-ui (Tailwind, Motion).",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/cap-jmk-real/next-spinner-kit.git"
  },
  "keywords": [
    "nextjs",
    "next",
    "react",
    "spinner",
    "loading",
    "ui",
    "shadcn",
    "registry"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./loading-ui": {
      "types": "./dist/loading-ui.d.ts",
      "import": "./dist/loading-ui.js",
      "require": "./dist/loading-ui.cjs"
    }
  },
  "files": [
    "dist",
    "media/next-spinners-overview.gif",
    "media/next-spinners-dotmatrix-overview.gif",
    "media/next-spinners-dotmatrix-overview-rows4.gif",
    "media/next-spinners-loading-ui-overview.gif",
    "media/next-spinners-mixed-x-showcase.gif",
    "media/readme-source-expo.gif",
    "media/readme-source-next-spinners.gif",
    "vendor/README.md",
    "vendor/loading-ui",
    "vendor/dot-matrix",
    "registry",
    "components.json.example"
  ],
  "scripts": {
    "build": "tsup",
    "lock:check": "node scripts/assert-emnapi-lock.mjs",
    "audit": "npm audit --audit-level=high",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "media:snapshot": "node scripts/build-spinner-frames-snapshot.mjs",
    "media:readme-pages": "node scripts/build-readme-attribution-pages.mjs",
    "media:readme-gifs": "node scripts/capture-readme-attribution-gifs.mjs",
    "media:gif": "node scripts/capture-overview-gif.mjs",
    "media:gif:dotmatrix": "node scripts/capture-dotmatrix-overview-gif.mjs",
    "media:gif:loading-ui": "node scripts/capture-loading-ui-overview-gif.mjs",
    "media:gif:mixed-x": "node scripts/capture-mixed-x-showcase-gif.mjs",
    "port:loading-ui": "node scripts/port-loading-ui-to-src.mjs",
    "vendor:sync": "node scripts/vendor-sync.mjs",
    "registry:shadcn": "node scripts/build-shadcn-registry.mjs",
    "version:patch": "npm version patch -m \"chore: release %s\"",
    "version:minor": "npm version minor -m \"chore: release %s\"",
    "version:major": "npm version major -m \"chore: release %s\"",
    "ci": "npm run lock:check && npm run registry:shadcn && npm run format:check && npm run typecheck && npm run lint && npm run test:coverage",
    "docs:dev": "npm run dev --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "ci:local": "node scripts/check-version-not-released.mjs && npm run ci && npm run build",
    "git:require-clean": "node scripts/assert-git-clean.mjs",
    "ci:verify": "npm run ci && npm run git:require-clean",
    "deploy": "npm run ci && npm run build",
    "prepublishOnly": "npm run ci && npm run build",
    "predev": "npm run lock:check"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0 || ^3.0.0",
    "motion": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "clsx": {
      "optional": true
    },
    "tailwind-merge": {
      "optional": true
    },
    "motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "clsx": "^2.1.1",
    "motion": "^12.23.12",
    "tailwind-merge": "^3.5.0",
    "@eslint/js": "^9.39.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
